# PostgreSQL
POSTGRES_USER=lframework
POSTGRES_PASSWORD=lframework
POSTGRES_DB=lframework
POSTGRES_PORT=5432
POSTGRES_HOST=localhost

# Connection strings (use in services)
DATABASE_URL=postgresql://lframework:lframework@localhost:5432/lframework
# Same DB for example; use separate DBs in production
IDENTITY_DATABASE_URL=postgresql://lframework:lframework@localhost:5432/lframework
CATALOG_DATABASE_URL=postgresql://lframework:lframework@localhost:5432/lframework

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

# RabbitMQ
RABBITMQ_USER=lframework
RABBITMQ_PASSWORD=lframework
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_URL=amqp://lframework:lframework@localhost:5672

# Service ports
IDENTITY_SERVICE_PORT=3001
CATALOG_SERVICE_PORT=3002

# API Gateway (Nginx)
GATEWAY_PORT=8080

# Auth (identity-service)
JWT_SECRET=change-me-in-production-use-a-long-random-secret
JWT_EXPIRES_IN_SECONDS=604800
BASE_URL=http://localhost:3001
# CORS: origens permitidas (separadas por vírgula). Vazio = sem CORS (apenas same-origin).
# Ex.: https://app.example.com ou http://localhost:5173,http://localhost:3000
CORS_ORIGIN=

# OAuth (opcional; deixe em branco para desativar)
# Google: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GitHub: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

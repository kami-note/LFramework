# PostgreSQL (Docker Compose + connection strings for services)
POSTGRES_USER=lframework
POSTGRES_PASSWORD=lframework
POSTGRES_DB=lframework
POSTGRES_PORT=5432

# Connection strings (use in services; separate DBs per service)
DATABASE_URL=postgresql://lframework:lframework@localhost:5432/lframework
IDENTITY_DATABASE_URL=postgresql://lframework:lframework@localhost:5432/lframework_identity
CATALOG_DATABASE_URL=postgresql://lframework:lframework@localhost:5432/lframework

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

# RabbitMQ (Docker Compose)
RABBITMQ_USER=lframework
RABBITMQ_PASSWORD=lframework
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_URL=amqp://lframework:lframework@localhost:5672

# Portas dos serviços
IDENTITY_SERVICE_PORT=3001
CATALOG_SERVICE_PORT=3002
API_DOCS_PORT=3003

# Nginx no Docker: porta no host (container escuta 80). Sem Docker use 80 no host.
GATEWAY_PORT=8080

# Identity: auth
JWT_SECRET=change-me-in-production-use-a-long-random-secret
JWT_EXPIRES_IN_SECONDS=604800
BASE_URL=http://localhost:3001
CORS_ORIGIN=

# OAuth (opcional; deixe em branco para desativar)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

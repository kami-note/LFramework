generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma-client"
}

datasource db {
  provider = "postgresql"
  url      = env("IDENTITY_DATABASE_URL")
}

model UserModel {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  createdAt DateTime @map("created_at")

  @@map("users")
}
